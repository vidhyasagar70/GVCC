{
  "name": "learning-portal-server",
  "version": "1.0.0",
  "description": "MERN Learning Portal — Express + TypeScript backend",
  "private": true,
  "main": "dist/app.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev":   "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint":  "tsc --noEmit"
  },
  "dependencies": {
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-async-errors": "^3.1.1",
    "mongoose":             "^8.4.1",
    "typescript":           "^5.4.5"
  },
  "devDependencies": {
    "@types/cors":    "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node":    "^20.14.2",
    "ts-node-dev":    "^2.0.0"
  }
}
